# Copy to .env and fill in. Restart `npm run dev` after changes.
# Create or rotate keys: https://aistudio.google.com/apikey (if expired/invalid, make a new key here)
#
# For GitHub Pages: Vite bakes these in at *build* time. Add secrets in CI
# (e.g. GitHub Actions) and pass them to `vite build`, or the chat has no key in production.

VITE_GEMINI_API_KEY=
# Optional — default is gemini-2.5-flash-lite (better free-tier limits than deprecated 2.0)
# VITE_GEMINI_MODEL=gemini-2.5-flash
